      "type": "date",
      "required": true,
      "label": "结束日期",
      "default": "2026-05-25"
    },
    {
      "name": "offset",
      "type": "number",
      "required": false,
      "label": "偏移量",
      "default": "0"
    },
    {
      "name": "format",
      "type": "select",
      "required": false,
      "label": "返回格式",
      "default": "json",
      "options": [
        {
          "value": "json",
          "label": "JSON"
        },
        {
          "value": "csv",
          "label": "CSV"
        }
      ]
    },
    {
      "name": "swindexcodes",
      "type": "multiselect",
      "required": false,
      "label": "申万行业",
      "option_source": "swindexcode",
      "placeholder": "801010,801030"
    }
  ],
  "columns_zh": {
